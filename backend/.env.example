# USC-PIS Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file with real credentials to version control

# Development settings
DEBUG=False

# SECURITY: Generate a new secret key for production
# Use: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secure-secret-key-here

# Database Configuration
# Production PostgreSQL example:
DATABASE_URL=postgres://username:password@host:port/database_name

# Local development SQLite alternative:
# DATABASE_URL=sqlite:///db.sqlite3

# Email Configuration
# Option 1: Gmail API (Modern OAuth 2.0) - Recommended
USE_GMAIL_API=False
GMAIL_CLIENT_ID=your-google-client-id
GMAIL_CLIENT_SECRET=your-google-client-secret
GMAIL_REFRESH_TOKEN=your-google-refresh-token
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Option 2: AWS SES
USE_AWS_SES=False
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_SES_REGION_NAME=us-east-1

# Option 3: Standard SMTP (Legacy)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-app-password

# Additional Security Settings
# ALLOWED_HOSTS=your-domain.com,localhost,127.0.0.1
# CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# pgcrypto encryption key (PostgreSQL only)
# Choose a strong symmetric key for PGP encryption of selected columns
PGP_ENCRYPTION_KEY=change_this_to_a_strong_key
