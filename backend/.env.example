# USC-PIS Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file with real credentials to version control

# --- Core Settings ---
DEBUG=False
SECRET_KEY=your-secure-secret-key-here
ALLOWED_HOSTS=usc-pis.herokuapp.com,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://usc-pis.herokuapp.com,http://localhost:5173

# --- Database & Security ---
DATABASE_URL=postgres://username:password@host:port/database_name
# pgcrypto symmetric encryption key for clinical fields
PGP_ENCRYPTION_KEY=choose_a_very_strong_random_string

# --- Media Storage (Cloudinary) ---
# Required for persistent uploads in production
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- Asynchronous Tasks (Redis) ---
# Required for Celery (Reporting, Automated Emails)
REDIS_URL=redis://localhost:6379/0

# --- Email Infrastructure (Gmail API) ---
# The system exclusively uses the Gmail API (OAuth 2.0) for clinical alerts.
# SMTP and AWS SES are disabled in the production settings.
GMAIL_CLIENT_ID=your-google-client-id
GMAIL_CLIENT_SECRET=your-google-client-secret
GMAIL_REFRESH_TOKEN=your-google-refresh-token
DEFAULT_FROM_EMAIL=21100727@usc.edu.ph

# --- Deployment Settings ---
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
